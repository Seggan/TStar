{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "SPCCObjectSchema",
    "type": ["object", "array"],
    "items": {
        "type": "object",
        "properties": {
            "model": {
                "type": "string"
            },
            "name": {
                "type": "string"
            },
            "is_dslr": {
                "type": "boolean"
            },
            "type": {
                "type": "string",
                "enum": [
                    "MONO_SENSOR",
                    "OSC_SENSOR",
                    "MONO_FILTER",
                    "OSC_FILTER",
                    "OSC_LPF",
                    "WB_REF"
                ]
            },
            "dataQualityMarker": {
                "type": "integer",
                "enum": [1, 2, 3, 4, 5]
            },
            "dataSource": {
                "type": "string"
            },
            "comment": {
                "type": "string"
            },
            "manufacturer": {
                "type": "string"
            },
            "version": {
                "type": "integer",
                "minimum": 1
            },
            "channel": {
                "type": "string",
                "enum": ["RED", "GREEN", "BLUE", "RED GREEN", "GREEN RED", "RED BLUE", "BLUE RED", "GREEN BLUE", "BLUE GREEN", "ALL", "LUM", "UV", "IR", "INVIS"]
            },
            "comment": {
                "type": "string"
            },
            "wavelength": {
            "type": "object",
            "properties": {
              "value": {
                "type": "array",
                "items": {
                  "type": "number",
                  "minimum": 0
                 }
              },
              "units": {
                "type": "string",
                "enum": ["nm", "micrometer", "angstrom", "m"]
              }
            },
            "required": [
              "value",
              "units"
            ],
            "minItems": 5,
            "maxItems": 2000
          },
          "values": {
            "type": "object",
            "properties": {
              "value": {
                "type": "array",
                "items": {
                  "type": "number",
                  "minimum": 0
                }
              },
              "range": {
                "type": "number",
                "minimum": 0
              }
            },
            "required": [
              "value",
              "range"
            ],
            "minItems": 5,
            "maxItems": 2000
          }
        },
        "required": [
            "model",
            "name",
            "type",
            "dataQualityMarker",
            "dataSource",
            "manufacturer",
            "version",
            "wavelength",
            "values"
        ],
        "dependencies": {
            "string": {
                "oneOf": [
                    {
                        "properties": {
                            "string": {
                                "enum": [
                                    "OSC_SENSOR",
                                ]
                            },
                            "channel": {
                                "type": "string",
                                "enum": ["RED", "GREEN", "BLUE"]
                            }
                        },
                        "required": [
                            "channel"
                        ]
                    },
                    {
                        "properties": {
                            "string": {
                                "enum": [
                                    "MONO_FILTER"
                                ]
                            },
                            "channel": {
                                "type": "string",
                                "enum": ["RED", "GREEN", "BLUE", "RED GREEN", "GREEN RED", "RED BLUE", "BLUE RED", "GREEN BLUE", "BLUE GREEN", "ALL", "LUM", "UV", "IR", "INVIS"]
                            }
                        },
                        "required": [
                            "channel"
                        ]
                    },
                    {
                        "properties": {
                            "string": {
                                "enum": [
                                    "OSC_FILTER",
                                    "MONO_SENSOR"
                                ]
                            }
                        }
                    }
                ]
            }
        },
        "allOf": [
            {
                "if": {
                    "not": {
                        "equal": {
                            "property": "wavelength",
                            "const": {
                                "$data": "1/values"
                            }
                        }
                    }
                },
                "then": {
                    "description": "The number of items in 'wavelength' array must be equal to the number of items in 'values' array."
                }
            }
        ]
    }
}

# =============================================================================
# TStar Project - Git Ignore Rules
# =============================================================================

# -----------------------------------------------------------------------------
# Build Artifacts & Output Directories
# -----------------------------------------------------------------------------
build/
build_win/
cmake-build-*/
out/
dist/
installer_output/
QM_OUTPUT_DIRECTORY
RESOURCE

# -----------------------------------------------------------------------------
# External Dependencies (downloaded/built separately by each developer)
# -----------------------------------------------------------------------------
deps/

# -----------------------------------------------------------------------------
# IDE & Editor Configuration Files
# -----------------------------------------------------------------------------

# Visual Studio
.vs/
*.user
*.suo
*.sln
*.vcxproj*
CMakeSettings.json

# Visual Studio Code
.vscode/

# JetBrains IDEs
.idea/

# Vim / Neovim swap files
*.swp
*.swo
*~

# Qt Creator
*.pro.user*
*.qbs.user*
CMakeLists.txt.user*

# -----------------------------------------------------------------------------
# Compiled Object Files & Binaries
# -----------------------------------------------------------------------------
*.o
*.obj
*.exe
*.dll
*.so
*.dylib
*.a
*.lib
*.pdb
*.ilk
*.exp

# -----------------------------------------------------------------------------
# CMake Generated Files
# -----------------------------------------------------------------------------
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
*.cmake
!CMakeLists.txt

# -----------------------------------------------------------------------------
# Qt Auto-Generated Files
# -----------------------------------------------------------------------------
moc_*.cpp
ui_*.h
qrc_*.cpp
*.qm

# -----------------------------------------------------------------------------
# Operating System Files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Logs & Temporary Files
# -----------------------------------------------------------------------------
*.log
build_log.txt
*.tmp
*.temp

# -----------------------------------------------------------------------------
# Python Artifacts
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class